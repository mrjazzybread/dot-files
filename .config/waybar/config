    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 50,
    "modules-left": ["hyprland/workspaces","cpu","memory","disk"],
    "modules-center":["mpd"],
    "modules-right": ["battery","clock","pulseaudio","pulseaudio#microphone","tray"],
    

    "hyprland/window": {
        "format": "{}"
